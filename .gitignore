# ---------------------------------------
# Obsidian Vault (choose one approach)
# ---------------------------------------

# Option A: Ignore everything in vault except markdown notes
obsidian-vault/*
!obsidian-vault/**/
!obsidian-vault/**/*.md

# Ignore Obsidian app metadata
.obsidian/
obsidian-vault/**/.obsidian/

# ---------------------------------------
# Temporary exports / generated docs
# ---------------------------------------
*.pdf
*.pptx
*.tmp
*.bak

# ---------------------------------------
# Python (if you later add scripts)
# ---------------------------------------
__pycache__/
*.pyc
.venv/
venv/

# ---------------------------------------
# Terraform (if later used for hosting)
# ---------------------------------------
.terraform/
*.tfstate
*.tfstate.*
crash.log

