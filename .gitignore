# ---------------------------------------
# Node / React / Vite
# ---------------------------------------
node_modules/
dist/
build/
.vite/
coverage/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ---------------------------------------
# Environment / Secrets
# ---------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------
# OS / Editor Files
# ---------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
.history/

